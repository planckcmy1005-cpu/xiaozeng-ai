# 百炼 API Key（语音识别 ASR + 声音复刻 TTS）
# 在 https://bailian.console.aliyun.com/ 获取
DASHSCOPE_API_KEY=sk-你的百炼Key

# 微调模型（阿里云专属 maas 地址）
# 如果没有微调模型，可以用 DeepSeek 等兼容 API 代替
OPENAI_API_KEY=sk-你的百炼Key
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-plus

# 克隆音色 ID（跑 clone_voice.py 后自动生成，留空则自动读取 voice_id.txt）
LAOZENG_VOICE_ID=

# 服务端口
PORT=7863
